# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=konjoai

# ─── Embedding ────────────────────────────────────────────────────────────────
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DEVICE=mps
EMBED_BATCH_SIZE=64

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNK_STRATEGY=recursive

# ─── Retrieval ────────────────────────────────────────────────────────────────
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANK=5
HYBRID_ALPHA=0.7

# ─── Generation ───────────────────────────────────────────────────────────────
GENERATOR_BACKEND=squish
MAX_TOKENS=1024
TEMPERATURE=0.1

# Squish (local inference server on port 3333)
SQUISH_BASE_URL=http://127.0.0.1:3333/v1
SQUISH_MODEL=Qwen2.5-7B-Instruct-int3

# ─── RAGAS Eval ───────────────────────────────────────────────────────────────
RAGAS_LLM=Qwen2.5-7B-Instruct-int3
